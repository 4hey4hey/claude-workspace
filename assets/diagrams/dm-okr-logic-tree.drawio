<mxfile>
  <diagram name="OKR Logic Tree" id="logic-tree">
    <mxGraphModel dx="1000" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="450" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Objective (top) -->
        <mxCell id="obj" value="&lt;b style=&quot;font-size:13px&quot;&gt;Objective&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;投資が最短・最確実に顧客価値へ変換される&lt;br&gt;デリバリーラインを確立する&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#004098;fontColor=#ffffff;strokeColor=#004098;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="20" width="380" height="70" as="geometry"/>
        </mxCell>
        <!-- Challenge KRs -->
        <mxCell id="kr1" value="&lt;b style=&quot;color:#2563EB&quot;&gt;挑戦KR1&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;入口品質を確立し&lt;br&gt;仕様起因の手戻りコストを&lt;br&gt;限りなくゼロに近づける&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#2563EB;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="170" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="kr2" value="&lt;b style=&quot;color:#7C3AED&quot;&gt;挑戦KR2&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;サイクルタイムを&lt;br&gt;現状比50%短縮する&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#7C3AED;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="275" y="170" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="kr3" value="&lt;b style=&quot;color:#059669&quot;&gt;挑戦KR3&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;投資判断の学習サイクルを&lt;br&gt;全チームで定着させる&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#059669;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="170" width="210" height="85" as="geometry"/>
        </mxCell>
        <!-- Foundation KR -->
        <mxCell id="base" value="&lt;b style=&quot;color:#F97316&quot;&gt;基盤KR&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;チーム健全性と育成基盤を確立する&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#F97316;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="765" y="170" width="210" height="85" as="geometry"/>
        </mxCell>
        <!-- Sub-items of foundation -->
        <mxCell id="base1" value="&lt;span style=&quot;font-size:10px&quot;&gt;健全性スコア&lt;br&gt;全チーム「良好」以上&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="765" y="320" width="100" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="base2" value="&lt;span style=&quot;font-size:10px&quot;&gt;チーフ育成計画&lt;br&gt;達成率100%&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="875" y="320" width="100" height="55" as="geometry"/>
        </mxCell>
        <!-- Pillar labels -->
        <mxCell id="lbl1" value="&lt;span style=&quot;font-size:9px;color:#444466&quot;&gt;入口品質 / 見極める&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="55" y="260" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lbl2" value="&lt;span style=&quot;font-size:9px;color:#444466&quot;&gt;フロー効率 / 速くする&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="260" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lbl3" value="&lt;span style=&quot;font-size:9px;color:#444466&quot;&gt;学習ループ / 見極める&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="545" y="260" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lbl4" value="&lt;span style=&quot;font-size:9px;color:#444466&quot;&gt;サステナビリティ&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="810" y="260" width="120" height="20" as="geometry"/>
        </mxCell>
        <!-- Edges: Objective to KRs -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="obj" target="kr1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="obj" target="kr2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="obj" target="kr3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="obj" target="base">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Edges: Foundation to sub-items -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.35;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="base" target="base1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.65;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="base" target="base2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Causal chain arrows (KR1→KR2→KR3) -->
        <mxCell id="chain1" style="strokeColor=#2563EB;strokeWidth=1.5;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="kr1" target="kr2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="chain2" style="strokeColor=#7C3AED;strokeWidth=1.5;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="kr2" target="kr3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
