<mxfile host="app.diagrams.net">
  <diagram id="kr-causal" name="KR間の因果関係：入口→フロー→学習の循環">
    <mxGraphModel dx="1422" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== Objective ===== -->
        <mxCell id="2" value="O: 投資が最短・最確実に顧客価値へ変換されるデリバリーラインを確立する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A5F;fontColor=#FFFFFF;strokeColor=none;fontSize=13;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="175" y="20" width="770" height="45" as="geometry"/>
        </mxCell>

        <!-- ===== バリューチェーンフローラベル ===== -->
        <mxCell id="3" value="&lt;font color=&quot;#6B7280&quot; style=&quot;font-size:11px&quot;&gt;── 開発バリューチェーン ──&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="75" width="420" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== KR1: 入口品質 ===== -->
        <mxCell id="10" value="&lt;div style=&quot;padding:6px 0 2px&quot;&gt;&lt;b style=&quot;font-size:14px;color:#1E40AF&quot;&gt;挑戦KR1&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;font-size:12px&quot;&gt;入口品質&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;見極める ／ PO&lt;/font&gt;&lt;/div&gt;&lt;hr color=&quot;#93C5FD&quot;&gt;&lt;div style=&quot;text-align:left;font-size:11px;padding:2px 10px;line-height:1.6&quot;&gt;バックログ健全性 80%以上&lt;br&gt;仕様起因手戻り 80%削減&lt;br&gt;意思決定LT 2営業日以内&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1E40AF;strokeWidth=2;arcSize=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="108" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== KR2: フロー効率 ===== -->
        <mxCell id="11" value="&lt;div style=&quot;padding:6px 0 2px&quot;&gt;&lt;b style=&quot;font-size:14px;color:#065F46&quot;&gt;挑戦KR2&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;font-size:12px&quot;&gt;フロー効率&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;速くする ／ SM + PO&lt;/font&gt;&lt;/div&gt;&lt;hr color=&quot;#6EE7B7&quot;&gt;&lt;div style=&quot;text-align:left;font-size:11px;padding:2px 10px;line-height:1.6&quot;&gt;サイクルタイム 50%短縮&lt;br&gt;ゴール達成率 80%以上&lt;br&gt;リリース予測精度 ±3日&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D1FAE5;strokeColor=#065F46;strokeWidth=2;arcSize=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="410" y="108" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== KR3: 学習ループ ===== -->
        <mxCell id="12" value="&lt;div style=&quot;padding:6px 0 2px&quot;&gt;&lt;b style=&quot;font-size:14px;color:#92400E&quot;&gt;挑戦KR3&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;font-size:12px&quot;&gt;学習ループ&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6B7280&quot; style=&quot;font-size:10px&quot;&gt;見極める ／ PO&lt;/font&gt;&lt;/div&gt;&lt;hr color=&quot;#FCD34D&quot;&gt;&lt;div style=&quot;text-align:left;font-size:11px;padding:2px 10px;line-height:1.6&quot;&gt;価値仮説検証率 80%以上&lt;br&gt;PdM月次フィードバック定着&lt;br&gt;検証起因のBL変更 50%以上&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#92400E;strokeWidth=2;arcSize=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="790" y="108" width="280" height="200" as="geometry"/>
        </mxCell>

        <!-- ===== Forward Arrow: KR1 → KR2 ===== -->
        <mxCell id="20" value="&lt;div style=&quot;font-size:9px;background:#FFFFFF;padding:2px 4px&quot;&gt;入口品質↑→手戻り↓&lt;br&gt;→フロー改善&lt;/div&gt;" style="html=1;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;strokeColor=#374151;strokeWidth=2;endArrow=blockThin;endFill=1;labelBackgroundColor=none;verticalAlign=bottom;" edge="1" source="10" target="11" parent="1">
          <mxGeometry x="-0.05" y="-10" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Forward Arrow: KR2 → KR3 ===== -->
        <mxCell id="22" value="&lt;div style=&quot;font-size:9px;background:#FFFFFF;padding:2px 4px&quot;&gt;速く届く→検証頻度↑&lt;br&gt;→学習加速&lt;/div&gt;" style="html=1;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;strokeColor=#374151;strokeWidth=2;endArrow=blockThin;endFill=1;labelBackgroundColor=none;verticalAlign=bottom;" edge="1" source="11" target="12" parent="1">
          <mxGeometry x="-0.05" y="-10" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== Return Arrow: KR3 → KR1 (学習フィードバックループ) ===== -->
        <mxCell id="30" style="exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#DC2626;strokeWidth=3;endArrow=blockThin;endFill=1;edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="12" target="10" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="930" y="395"/>
              <mxPoint x="170" y="395"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== Return Arrow Label ===== -->
        <mxCell id="31" value="&lt;font style=&quot;font-size:10px;color:#DC2626&quot;&gt;&lt;b&gt;学習結果&lt;/b&gt; → PdMフィードバック → 仮説精度↑ → &lt;b&gt;バックログ品質↑&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="400" width="620" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== 基盤セクション ===== -->
        <mxCell id="40" value="&lt;font style=&quot;font-size:10px;color:#6B7280&quot;&gt;▲ 全挑戦KRの前提条件&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="440" width="320" height="22" as="geometry"/>
        </mxCell>

        <!-- ===== 基盤KR1: チーム健全性 ===== -->
        <mxCell id="41" value="&lt;b&gt;基盤KR1：チーム健全性&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;全チーム「良好」以上で維持（守る / SM）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#9CA3AF;strokeWidth=1.5;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="470" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== 基盤KR2: チーフ育成 ===== -->
        <mxCell id="42" value="&lt;b&gt;基盤KR2：チーフ育成&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;マイルストーン達成率 100%（強くする / SM）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#9CA3AF;strokeWidth=1.5;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="470" width="340" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
