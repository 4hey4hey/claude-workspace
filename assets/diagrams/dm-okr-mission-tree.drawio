<mxfile>
  <diagram name="Mission Structure" id="mission-tree">
    <mxGraphModel dx="1000" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="450" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Mission (top) -->
        <mxCell id="2" value="&lt;b style=&quot;font-size:14px&quot;&gt;Mission&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px&quot;&gt;開発投資のリターンを最大化する&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#004098;fontColor=#ffffff;strokeColor=#004098;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="300" height="60" as="geometry"/>
        </mxCell>
        <!-- 3 pillars -->
        <mxCell id="3" value="&lt;b&gt;投資対効果&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;正しいものに正しい順番で投資する&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#004098;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="&lt;b&gt;スループット&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;速く届ける&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#004098;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="150" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="&lt;b&gt;サステナビリティ&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px&quot;&gt;走り続けられる&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EEF3FA;fontColor=#1A1A2E;strokeColor=#004098;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="150" width="260" height="55" as="geometry"/>
        </mxCell>
        <!-- Action principles -->
        <mxCell id="6" value="&lt;b&gt;見極める&lt;/b&gt;&lt;br&gt;PO" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="95" y="270" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="&lt;b&gt;速くする&lt;/b&gt;&lt;br&gt;SM + PO" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="425" y="270" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="8a" value="&lt;b&gt;守る&lt;/b&gt;&lt;br&gt;SM" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="270" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="8b" value="&lt;b&gt;強くする&lt;/b&gt;&lt;br&gt;SM + PO" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5f5f5;fontColor=#444466;strokeColor=#CADCFC;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="840" y="270" width="120" height="45" as="geometry"/>
        </mxCell>
        <!-- Edges: Mission to pillars -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="2" target="5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Edges: pillars to principles -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="3" target="6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="4" target="7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.35;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="5" target="8a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#94A3B8;strokeWidth=1.5;exitX=0.65;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="5" target="8b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
